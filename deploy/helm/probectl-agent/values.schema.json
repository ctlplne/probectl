{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "allowTagOnly": {
          "type": "boolean"
        },
        "pullPolicy": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "allowTagOnly": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "tag": {
                "pattern": "@sha256:[A-Fa-f0-9]{64}$"
              }
            },
            "required": ["tag"]
          }
        }
      ]
    },
    "admission": {
      "type": "object",
      "properties": {
        "imageIntegrity": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "acceptedRisk": {
              "type": "string"
            },
            "policyName": {
              "type": "string",
              "minLength": 1
            },
            "validationFailureAction": {
              "type": "string",
              "enum": ["Enforce", "Audit"]
            },
            "background": {
              "type": "boolean"
            },
            "imageReferences": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "issuer": {
              "type": "string",
              "format": "uri"
            },
            "subjectRegExp": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "capabilityPosture": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "policyName": {
              "type": "string",
              "minLength": 1
            },
            "validationFailureAction": {
              "type": "string",
              "enum": ["Enforce", "Audit"]
            },
            "background": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "l7Capture": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "consentTenant": {
          "type": "string"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(pid:[0-9]+|exe:/.*|cgroup:/.*)$"
          }
        },
        "redaction": {
          "type": "string",
          "enum": ["headers", "length", "full"]
        },
        "kernelWindow": {
          "type": "integer",
          "anyOf": [
            {
              "const": 0
            },
            {
              "minimum": 128,
              "maximum": 4095
            }
          ]
        },
        "identityHeaderFragments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "hashAllHeaderValues": {
          "type": "boolean"
        }
      }
    },
    "capabilityMode": {
      "type": "string",
      "enum": ["modern", "legacy"]
    },
    "legacyKernelRingBufferAck": {
      "type": "string"
    },
    "health": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": ["exec", "http"]
        },
        "stateDir": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "allowPlaintextHTTP": {
          "type": "boolean"
        }
      }
    }
  }
}
