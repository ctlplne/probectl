{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "allowTagOnly": {
          "type": "boolean"
        },
        "pullPolicy": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "allowTagOnly": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "tag": {
                "pattern": "@sha256:[A-Fa-f0-9]{64}$"
              }
            },
            "required": ["tag"]
          }
        }
      ]
    },
    "l7Capture": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "consentTenant": {
          "type": "string"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(pid:[0-9]+|exe:/.*|cgroup:/.*)$"
          }
        },
        "redaction": {
          "type": "string",
          "enum": ["headers", "length", "full"]
        },
        "kernelWindow": {
          "type": "integer",
          "anyOf": [
            {
              "const": 0
            },
            {
              "minimum": 128,
              "maximum": 4095
            }
          ]
        }
      }
    },
    "capabilityMode": {
      "type": "string",
      "enum": ["modern", "legacy"]
    },
    "legacyKernelRingBufferAck": {
      "type": "string"
    }
  }
}
