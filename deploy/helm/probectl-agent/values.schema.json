{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "allowTagOnly": {
          "type": "boolean"
        },
        "pullPolicy": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "allowTagOnly": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "tag": {
                "pattern": "@sha256:[A-Fa-f0-9]{64}$"
              }
            },
            "required": ["tag"]
          }
        }
      ]
    }
  }
}
