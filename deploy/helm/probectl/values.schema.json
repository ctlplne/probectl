{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "probectl Helm values",
  "description": "Schema for the probectl control-plane chart. Validated by Helm on install/upgrade/template. Security-relevant blocks are typed; the chart stays HTTPS-by-default and refuses to render without envelope and session-HMAC keys (no default credentials).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      },
      "required": ["repository"]
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "migrateOnBoot": { "type": "boolean" },
    "publicTLS": { "type": "boolean" },
    "allowPlaintextHTTP": { "type": "boolean" },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "scheme": { "type": "string", "enum": ["http", "https"] },
            "labels": { "type": "object" },
            "tlsConfig": { "type": "object" }
          }
        },
        "prometheusRule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "labels": { "type": "object" },
            "runbookBaseURL": { "type": "string", "minLength": 1 },
            "thresholds": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "noSelfMetricsFor": { "type": "string", "minLength": 1 },
                "highGoroutines": { "type": "integer", "minimum": 1 },
                "highGoroutinesFor": { "type": "string", "minLength": 1 },
                "highMemoryBytes": { "type": "integer", "minimum": 1 },
                "highMemoryFor": { "type": "string", "minLength": 1 },
                "writesPausedFor": { "type": "string", "minLength": 1 },
                "replicaLagSeconds": { "type": "integer", "minimum": 1 },
                "replicaLagFor": { "type": "string", "minLength": 1 },
                "dlqGrowthWindow": { "type": "string", "minLength": 1 },
                "dlqGrowthEvents": { "type": "integer", "minimum": 0 },
                "dlqGrowthFor": { "type": "string", "minLength": 1 },
                "busErrorWindow": { "type": "string", "minLength": 1 },
                "busErrorEvents": { "type": "integer", "minimum": 0 },
                "busErrorFor": { "type": "string", "minLength": 1 },
                "clickhouseFailureWindow": { "type": "string", "minLength": 1 },
                "clickhouseFailureEvents": { "type": "integer", "minimum": 0 },
                "clickhouseFailureFor": { "type": "string", "minLength": 1 },
                "agentDarkFleetFraction": { "type": "number", "minimum": 0, "maximum": 1 },
                "agentDarkFleetFor": { "type": "string", "minLength": 1 },
                "fairnessWindow": { "type": "string", "minLength": 1 },
                "fairnessEvents": { "type": "integer", "minimum": 0 },
                "fairnessFor": { "type": "string", "minLength": 1 },
                "wormExportGapSeconds": { "type": "integer", "minimum": 1 },
                "wormExportGapFor": { "type": "string", "minLength": 1 },
                "wormVerifyFailureWindow": { "type": "string", "minLength": 1 },
                "wormVerifyFailures": { "type": "integer", "minimum": 0 },
                "wormVerifyFailureFor": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "restore": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "backupFile": { "type": "string" },
        "host": { "type": "string" },
        "database": { "type": "string" },
        "image": { "type": "string" },
        "clickhouse": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "backupFile": { "type": "string" },
            "serverBackupPath": { "type": "string", "minLength": 1 },
            "host": { "type": "string" },
            "database": { "type": "string" },
            "image": { "type": "string" }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "credentialsSecret": { "type": "string" },
        "encryption": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "keySecret": { "type": "string" },
            "keySecretKey": { "type": "string" }
          }
        },
        "resources": { "type": "object" },
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": { "type": "boolean" },
            "claimName": { "type": "string" },
            "size": { "type": "string" },
            "storageClass": { "type": "string" }
          }
        },
        "postgres": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": { "type": "string" },
            "host": { "type": "string" },
            "database": { "type": "string" },
            "image": { "type": "string" }
          }
        },
        "clickhouse": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": { "type": "string" },
            "host": { "type": "string" },
            "database": { "type": "string" },
            "serverBackupPath": { "type": "string", "minLength": 1 },
            "image": { "type": "string" }
          }
        }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "authMode": { "type": "string", "enum": ["session", "dev"] },
        "logFormat": { "type": "string", "enum": ["json", "text"] },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "securityContact": { "type": "string" },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "existingSecret": { "type": "string" },
            "certKey": { "type": "string", "minLength": 1 },
            "keyKey": { "type": "string", "minLength": 1 },
            "mountPath": { "type": "string", "minLength": 1 }
          }
        },
        "extraEnv": { "type": "object" }
      }
    },
    "oidc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issuer": { "type": "string" },
        "clientId": { "type": "string" },
        "clientSecret": { "type": "string" },
        "redirectUrl": { "type": "string" }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": { "type": "string" },
        "envelopeKey": { "type": "string" },
        "sessionHMACKey": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "url": { "type": "string", "minLength": 1 } },
      "required": ["url"]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "tlsSecretName": { "type": "string" },
        "hstsMaxAge": { "type": "integer", "minimum": 0 },
        "annotations": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string", "null"] }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressFrom": { "type": "array" },
        "egressTo": { "type": "array" }
      }
    },
    "topologySpreadConstraints": { "type": "array" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" }
  }
}
