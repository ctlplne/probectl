# Copy to terraform.tfvars and fill in. NEVER commit real secrets — source them
# from your secret manager / CI variables / a *.auto.tfvars that is gitignored.

kubeconfig         = "~/.kube/config"
size               = "medium"
ingress_host       = "probectl.example.com"
ingress_tls_secret = "probectl-tls"

# Point at your managed Postgres.
database_url = "postgres://probectl:CHANGEME@db.internal:5432/probectl?sslmode=require"

# openssl rand -base64 32
envelope_key = "REPLACE_WITH_BASE64_32_BYTE_KEK"

# openssl rand -hex 32
session_hmac_key = "REPLACE_WITH_HEX_32_BYTE_SESSION_HMAC_KEY"
