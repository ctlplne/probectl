{
  "openapi": "3.1.0",
  "info": {
    "title": "netctl control-plane API",
    "version": "0.1.0",
    "description": "Operational endpoints plus the versioned /v1 resource API. All /v1 routes are tenant-scoped; in S9 the tenant is resolved by a dev stub (default tenant, optional X-Netctl-Tenant override) — real identity (SSO/SCIM, per-tenant IdP) lands in S18."
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "operational", "description": "Health, readiness, and build metadata." },
    { "name": "tests", "description": "Synthetic test definitions." },
    { "name": "agents", "description": "Registered agents (created via mTLS registration; managed here)." }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getHealthz",
        "summary": "Liveness probe",
        "tags": ["operational"],
        "responses": {
          "200": {
            "description": "Process is alive.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "operationId": "getReadyz",
        "summary": "Readiness probe",
        "description": "Returns 200 when dependencies (the database) are reachable, otherwise 503.",
        "tags": ["operational"],
        "responses": {
          "200": {
            "description": "Dependencies are reachable.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } }
          },
          "503": {
            "description": "A dependency is not ready.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/version": {
      "get": {
        "operationId": "getVersion",
        "summary": "Build metadata",
        "tags": ["operational"],
        "responses": {
          "200": {
            "description": "Build and runtime metadata.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Version" } } }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "operationId": "getOpenAPI",
        "summary": "This OpenAPI 3.1 document",
        "tags": ["operational"],
        "responses": {
          "200": {
            "description": "The OpenAPI 3.1 document.",
            "content": { "application/json": {} }
          }
        }
      }
    },
    "/v1/tests": {
      "get": {
        "operationId": "listTests",
        "summary": "List synthetic tests",
        "tags": ["tests"],
        "parameters": [{ "$ref": "#/components/parameters/TenantHeader" }],
        "responses": {
          "200": {
            "description": "The tenant's tests.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TestList" } } }
          }
        }
      },
      "post": {
        "operationId": "createTest",
        "summary": "Create a synthetic test",
        "tags": ["tests"],
        "parameters": [{ "$ref": "#/components/parameters/TenantHeader" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TestRequest" } } }
        },
        "responses": {
          "201": {
            "description": "The created test.",
            "headers": { "Location": { "schema": { "type": "string" } } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Test" } } }
          },
          "409": { "$ref": "#/components/responses/ErrorResponse" },
          "422": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/v1/tests/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/TenantHeader" },
        { "$ref": "#/components/parameters/IdPath" }
      ],
      "get": {
        "operationId": "getTest",
        "summary": "Get a test",
        "tags": ["tests"],
        "responses": {
          "200": {
            "description": "The test.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Test" } } }
          },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "put": {
        "operationId": "updateTest",
        "summary": "Update a test",
        "tags": ["tests"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TestRequest" } } }
        },
        "responses": {
          "200": {
            "description": "The updated test.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Test" } } }
          },
          "404": { "$ref": "#/components/responses/ErrorResponse" },
          "409": { "$ref": "#/components/responses/ErrorResponse" },
          "422": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "delete": {
        "operationId": "deleteTest",
        "summary": "Delete a test",
        "tags": ["tests"],
        "responses": {
          "204": { "description": "Deleted." },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/v1/tests/{id}/path": {
      "parameters": [
        { "$ref": "#/components/parameters/TenantHeader" },
        { "$ref": "#/components/parameters/IdPath" }
      ],
      "get": {
        "operationId": "getTestPath",
        "summary": "Latest discovered network path for a test (path-viz data)",
        "tags": ["tests"],
        "responses": {
          "200": {
            "description": "The merged multi-path.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Path" } } }
          },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "post": {
        "operationId": "discoverTestPath",
        "summary": "Run a path discovery for a test and return the path",
        "tags": ["tests"],
        "responses": {
          "200": {
            "description": "The freshly discovered path.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Path" } } }
          },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/v1/agents": {
      "get": {
        "operationId": "listAgents",
        "summary": "List agents",
        "tags": ["agents"],
        "parameters": [{ "$ref": "#/components/parameters/TenantHeader" }],
        "responses": {
          "200": {
            "description": "The tenant's agents.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentList" } } }
          }
        }
      }
    },
    "/v1/agents/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/TenantHeader" },
        { "$ref": "#/components/parameters/IdPath" }
      ],
      "get": {
        "operationId": "getAgent",
        "summary": "Get an agent",
        "tags": ["agents"],
        "responses": {
          "200": {
            "description": "The agent.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Agent" } } }
          },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "patch": {
        "operationId": "patchAgent",
        "summary": "Update an agent's display name",
        "tags": ["agents"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentPatch" } } }
        },
        "responses": {
          "200": {
            "description": "The updated agent.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Agent" } } }
          },
          "404": { "$ref": "#/components/responses/ErrorResponse" },
          "422": { "$ref": "#/components/responses/ErrorResponse" }
        }
      },
      "delete": {
        "operationId": "deleteAgent",
        "summary": "Deregister an agent",
        "tags": ["agents"],
        "responses": {
          "204": { "description": "Deleted." },
          "404": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "TenantHeader": {
        "name": "X-Netctl-Tenant",
        "in": "header",
        "required": false,
        "description": "Dev stub (S9): a tenant UUID to scope the request to. Omitted → the default tenant. Replaced by session-resolved identity in S18.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "An error envelope.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "schemas": {
      "Health": {
        "type": "object",
        "properties": { "status": { "type": "string", "examples": ["ok", "ready"] } },
        "required": ["status"]
      },
      "Version": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "commit": { "type": "string" },
          "date": { "type": "string" },
          "go_version": { "type": "string" },
          "os": { "type": "string" },
          "arch": { "type": "string" }
        },
        "required": ["version", "commit", "date", "go_version", "os", "arch"]
      },
      "Error": {
        "type": "object",
        "description": "The standard error envelope returned by every endpoint.",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "request_id": { "type": "string" }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "TestRequest": {
        "type": "object",
        "description": "The mutable fields of a synthetic test.",
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 200 },
          "type": { "type": "string", "enum": ["icmp", "tcp", "udp", "dns", "http", "a2a", "noop"] },
          "target": { "type": "string", "description": "Required for all types except noop." },
          "interval_seconds": { "type": "integer", "minimum": 1, "maximum": 86400, "default": 60 },
          "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300, "default": 3 },
          "params": { "type": "object", "additionalProperties": { "type": "string" } },
          "enabled": { "type": "boolean", "default": true }
        },
        "required": ["name", "type"]
      },
      "Test": {
        "allOf": [
          { "$ref": "#/components/schemas/TestRequest" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "tenant_id": { "type": "string", "format": "uuid" },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" }
            },
            "required": ["id", "tenant_id", "created_at", "updated_at"]
          }
        ]
      },
      "TestList": {
        "type": "object",
        "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/Test" } } },
        "required": ["items"]
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "hostname": { "type": "string" },
          "agent_version": { "type": "string" },
          "status": { "type": "string", "enum": ["registered", "online", "offline"] },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "spiffe_id": { "type": "string" },
          "registered_at": { "type": "string", "format": "date-time" },
          "last_seen_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "tenant_id", "name", "status", "capabilities"]
      },
      "AgentPatch": {
        "type": "object",
        "properties": { "name": { "type": "string", "minLength": 1, "maxLength": 200 } },
        "required": ["name"]
      },
      "AgentList": {
        "type": "object",
        "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/Agent" } } },
        "required": ["items"]
      },
      "MPLSLabel": {
        "type": "object",
        "properties": {
          "label": { "type": "integer" },
          "tc": { "type": "integer" },
          "s": { "type": "boolean" },
          "ttl": { "type": "integer" }
        }
      },
      "HopNode": {
        "type": "object",
        "description": "One responder at a TTL; multiple nodes at a TTL are ECMP branches.",
        "properties": {
          "ip": { "type": "string" },
          "sent": { "type": "integer" },
          "received": { "type": "integer" },
          "loss_ratio": { "type": "number" },
          "rtt_min_ms": { "type": "number" },
          "rtt_avg_ms": { "type": "number" },
          "rtt_max_ms": { "type": "number" },
          "mpls": { "type": "array", "items": { "$ref": "#/components/schemas/MPLSLabel" } }
        },
        "required": ["ip"]
      },
      "Hop": {
        "type": "object",
        "properties": {
          "ttl": { "type": "integer" },
          "nodes": { "type": "array", "items": { "$ref": "#/components/schemas/HopNode" } }
        },
        "required": ["ttl", "nodes"]
      },
      "Link": {
        "type": "object",
        "properties": {
          "ttl": { "type": "integer" },
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      },
      "Path": {
        "type": "object",
        "description": "A merged, multi-path traceroute result.",
        "properties": {
          "target": { "type": "string" },
          "target_ip": { "type": "string" },
          "mode": { "type": "string" },
          "max_hops": { "type": "integer" },
          "trace_count": { "type": "integer" },
          "destination_reached": { "type": "boolean" },
          "hops": { "type": "array", "items": { "$ref": "#/components/schemas/Hop" } },
          "links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } }
        },
        "required": ["target", "mode", "hops", "links"]
      }
    }
  }
}
