{
  "name": "probectl-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "probectl frontend foundation & design system (S8a).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "i18n:check": "vitest run src/test/i18n.test.tsx",
    "prea11y:browser": "npm --prefix ../browser-worker ci --no-audit --no-fund",
    "a11y:browser": "node ../scripts/web_rendered_a11y.mjs",
    "coverage": "vitest run --coverage",
    "coverage-gate": "vitest run src/test/surface-coverage.test.tsx"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest-axe": "3.5.9",
    "@types/node": "22.19.19",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "15.15.0",
    "jest-axe": "9.0.0",
    "jsdom": "25.0.1",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "5.4.21",
    "vitest": "4.1.8"
  }
}
